{
  "experiment": "exp2_agreement_analysis",
  "description": "Run all small local medical judges on broad clinical QA rows under four published rubrics plus the PEMAT-Likert controlled scoring variant. Classify agreement per question across 5 clinical domains.",
  "judges": [
    {
      "id": "medgemma",
      "model": "google/medgemma-4b-it",
      "url": "http://localhost:8001"
    },
    {
      "id": "biomistral",
      "model": "BioMistral/BioMistral-7B",
      "url": "http://localhost:8002"
    },
    {
      "id": "meditron",
      "model": "epfl-llm/meditron-7b",
      "url": "http://localhost:8003"
    },
    {
      "id": "medalpaca",
      "model": "medalpaca/medalpaca-7b",
      "url": "http://localhost:8004"
    }
  ],
  "rubrics": [
    "rubrics/rubric1_pemat.json",
    "rubrics/rubric2_healthbench.json",
    "rubrics/rubric3_clinical_eval.json",
    "rubrics/rubric4_prometheus.json",
    "rubrics/rubric5_pemat_likert.json"
  ],
  "benchmark_csv": "benchmark_dataset/agreement_benchmark.csv",
  "domains": [
    "Cardiology",
    "Pharmacology",
    "Neurology",
    "Pediatrics",
    "Emergency"
  ],
  "agreement_threshold": 80.0,
  "temperature": 0.0,
  "max_tokens": 1024,
  "timeout_seconds": 120,
  "print_rationales": true,
  "output_files": {
    "results_json": "results/exp2_agreement_results.json",
    "figure_dir": "results/figures"
  }
}
