# Copy this file to .env and fill in real values
# cp .env.example .env

# HuggingFace token — required for gated models (e.g. medgemma)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# GitHub token — required for git push from notebook Cell 17
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# vLLM judge endpoints (launched by notebook Cell 5)
LOCAL_VLLM_JUDGE1_URL=http://localhost:8001   # medgemma   GPU 0
LOCAL_VLLM_JUDGE2_URL=http://localhost:8002   # biomistral GPU 1
LOCAL_VLLM_JUDGE3_URL=http://localhost:8003   # meditron   GPU 2

# BioMedLM FastAPI endpoint (launched by notebook Cell 4b)
LOCAL_VLLM_BIOMEDLM_URL=http://localhost:8004  # biomedlm  GPU 3

# Optional: shared API key passed to vLLM servers (leave as-is)
LOCAL_API_KEY=local-no-key-needed
